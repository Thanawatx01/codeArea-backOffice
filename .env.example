# Supabase (DB only, ไม่ใช้ Supabase Auth แล้ว)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket for question PDF assets (public bucket recommended for getPublicUrl)
SUPABASE_STORAGE_QUESTIONS_BUCKET=question-pdfs

# Custom Auth: JWT (stateless)
JWT_SECRET=your-super-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Server
PORT=3100
NODE_ENV=development

# Public frontend origin for password-reset links and production CORS
NEXT_PUBLIC_SITE_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
# Multiple origins allowed, comma-separated:
# CORS_ORIGIN=http://localhost:3000,https://your-vercel-app.vercel.app

# External services
EXECUTOR_TYPE=piston
EXECUTOR_URL=http://localhost:2000
AI_CONNECTOR_URL=http://localhost:8080

# Optional Redis URL if enabled by backend features
REDIS_URL=redis://localhost:6379
