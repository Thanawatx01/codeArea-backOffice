# Supabase (DB only, ไม่ใช้ Supabase Auth แล้ว)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket for question PDF assets (public bucket recommended for getPublicUrl)
SUPABASE_STORAGE_QUESTIONS_BUCKET=question-pdfs

# Custom Auth: JWT (stateless)
JWT_SECRET=your-super-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Piston code runner (POST /api/v2/execute) — ใช้ทั้ง submission judge และ EXECUTOR_TYPE=piston
PISTON_URL=http://localhost:2000

# Proxy /api/executor/execute: piston ใช้ PISTON_URL ด้านบน; Judge0 ใช้ EXECUTOR_URL
# EXECUTOR_TYPE=piston
# EXECUTOR_URL=http://localhost:2358
