# Supabase (DB only, ไม่ใช้ Supabase Auth แล้ว)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-secret-key
# Storage bucket for question PDF assets (public bucket recommended for getPublicUrl)
SUPABASE_STORAGE_QUESTIONS_BUCKET=question-pdfs
# Storage bucket for user profile images (public bucket recommended for getPublicUrl)
SUPABASE_STORAGE_PROFILES_BUCKET=user-profile-img

# Custom Auth: JWT (stateless)
# Generated automatically by `npm run setup:env` or root `npm run setup`.
# Manual fallback: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generated-by-setup-env
JWT_EXPIRES_IN=7d

# Server
PORT=3100
NODE_ENV=development
