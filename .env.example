# Supabase (DB only, ไม่ใช้ Supabase Auth แล้ว)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Storage bucket for question PDF assets (public bucket recommended for getPublicUrl)
SUPABASE_STORAGE_QUESTIONS_BUCKET=question-pdfs

# Custom Auth: JWT (stateless)
JWT_SECRET=your-super-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Executor URL used for both Piston and Judge0 backends
# - Set EXECUTOR_TYPE=piston and EXECUTOR_URL=http://localhost:2000 for Piston
# - Set EXECUTOR_TYPE=judge0 and EXECUTOR_URL=http://localhost:2358 for Judge0
EXECUTOR_TYPE=piston
EXECUTOR_URL=http://localhost:2000
